// Indirect recursion through tuple-returning functions: a() calls b() calls
// a(), a cycle one hop removed from the direct self-call in
// tuple_recursion_pass.aether. Tuple returns lower to a synthesized record
// returned by value (see buildSyntheticTupleRecordType/buildTempRecordReturn
// in ast_parser.c); the VM deep-copies a record on every return
// (returnFromCall/copyRecord in pscal-core), so each call frame in the cycle
// gets its own independent result. This used to be rejected at compile time
// (TUP-001's call-graph cycle check); it now compiles and runs correctly.
fn a(n: Int) -> (Int, Int) {
    if n <= 0 {
        ret (0, 0);
    }
    let (x, y) = b(n - 1);
    ret (x + 1, y + 2);
}

fn b(n: Int) -> (Int, Int) {
    let (x, y) = a(n - 1);
    ret (x, y);
}

fn main() -> Void {
    let (x, y) = a(3);
    fx {
        println(x);
        println(y);
    }
    ret;
}
