// Regression: a statement-level call to a `-> Void` method on an *inferred*
// object binding (`let c = new Counter();`, no `: Counter` annotation) must
// type-check the pointer-backed receiver exactly as the annotated form does.
//
// Records are pointer-backed, so the receiver of `c.inc();` is passed as the
// method's POINTER `self` argument. Before the fix, the inferred-`let` path
// built a bare TYPE_REFERENCE at TYPE_UNKNOWN for the user type, so a later
// statement-level Void-method call tripped pscal-core's
//   "argument 1 to 'c.inc' expects type POINTER but got VOID"
// while the annotated `let c: Counter = new Counter();` compiled. The inferred
// binding now routes through the same buildTypeNode() helper (record -> POINTER)
// as the annotation, so both forms are equivalent.
type Counter {
    value: Int;

    fn inc() -> Void {
        self.value = self.value + 1;
    }

    fn add(n: Int) -> Void {
        self.value = self.value + n;
    }
}

fn main() -> Void {
    let c = new Counter();
    c.value = 10;
    c.inc();          // statement-level `-> Void` call on the inferred receiver
    c.add(31);
    fx {
        println(c.value);
    }
    ret;
}
