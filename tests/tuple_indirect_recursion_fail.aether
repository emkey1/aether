// Indirect recursion through tuple-returning functions: a() calls b() calls
// a(), a cycle one hop removed from the direct self-call TUP-001 already
// covers. Tuple returns lower to per-slot globals (__aether_tuple_N_itemK),
// so this corrupts an in-flight caller's results exactly like a self-call --
// must be rejected at compile time too (see tuple_recursion_fail.aether).
fn a(n: Int) -> (Int, Int) {
    if n <= 0 {
        ret (0, 0);
    }
    let (x, y) = b(n - 1);
    ret (x + 1, y + 2);
}

fn b(n: Int) -> (Int, Int) {
    let (x, y) = a(n - 1);
    ret (x, y);
}

fn main() -> Void {
    let (x, y) = a(3);
    fx {
        println(x);
        println(y);
    }
    ret;
}
